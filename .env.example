# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_IDS=123456789,987654321

# Telegram User-ID für Benachrichtigungen (bekommt fertige Videos zugeschickt)
# NOTIFY_USER_ID=123456789

# ── Lokaler Bot API Server (für Docker-Deployment) ──────────────────────────
# Diese Werte bekommst du unter https://my.telegram.org → API Development Tools
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Video Settings (optional overrides)
# FLYER_STILL_DURATION=5
# ANIMAL_STILL_DURATION=5
# VIDEO_WIDTH=1920
# VIDEO_HEIGHT=1080
# VIDEO_FPS=30
